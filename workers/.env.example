# Worker API authentication key (shared with Convex WORKER_API_KEY)
WORKER_API_KEY=your-secret-key-here

# Node identifier for this worker instance
NODE_ID=vps-1

# Port for the Fastify server
PORT=3100

# Optional: Rate limiting config
# MAX_SERP_REQUESTS_PER_MINUTE=6
# REQUEST_DELAY_MIN_MS=3000
# REQUEST_DELAY_MAX_MS=8000

