{
  "name": "getwired",
  "version": "0.0.18",
  "description": "AI-powered CLI for visual regression and exploratory testing",
  "type": "module",
  "bin": {
    "getwired": "dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JaySym-ai/getwired.git"
  },
  "homepage": "https://github.com/JaySym-ai/getwired#readme",
  "bugs": {
    "url": "https://github.com/JaySym-ai/getwired/issues"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx watch src/cli.tsx",
    "build": "tsup",
    "prepare": "npm run build",
    "lint": "tsc --noEmit && npm run lint:patterns",
    "lint:patterns": "node scripts/check-patterns.mjs",
    "test": "tsx --test tests/integration/*.test.ts tests/unit/*.test.ts",
    "regression:smoke": "npm run build && node ./scripts/regression-smoke.mjs"
  },
  "keywords": [
    "testing",
    "cli",
    "ai",
    "qa",
    "e2e",
    "regression",
    "tui",
    "screenshot",
    "visual-regression"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@napi-rs/canvas": "^0.1.65",
    "commander": "^13.0.0",
    "ink": "^6.8.0",
    "playwright": "^1.59.1",
    "react": "^19.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
