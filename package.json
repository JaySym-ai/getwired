{
  "name": "getwired",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:web": "turbo dev --filter=@getwired/web",
    "dev:cli": "turbo dev --filter=@getwired/cli",
    "build:cli": "turbo build --filter=@getwired/cli"
  },
  "devDependencies": {
    "turbo": "^2.4.0"
  },
  "overrides": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@types/react": "^19.0.0"
  },
  "packageManager": "npm@10.9.0"
}
